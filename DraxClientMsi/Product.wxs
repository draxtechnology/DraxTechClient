<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Drax Technology Client"
           Manufacturer="Drax Technology"
           Version="1.0.0"
           UpgradeCode="BCDEEC3D-DD83-44D7-9AC4-783B277ECBC5"
           Scope="perMachine"
           InstallerVersion="500">

    <SummaryInformation Description="Drax Technology Client"
                        Keywords="Installer,Drax,Client" />

    <MajorUpgrade DowngradeErrorMessage="A later version of [ProductName] is already installed." />

    <Media Id="1" Cabinet="files.cab" EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="DraxClient.ico" SourceFile="..\Drax360Client\DT-small.ico" />
    <Property Id="ARPPRODUCTICON" Value="DraxClient.ico" />

    <Feature Id="Main" Title="Drax Client" Level="1">
      <ComponentGroupRef Id="ClientComponents" />
      <ComponentGroupRef Id="DependencyFiles" />
      <ComponentRef Id="StartMenuShortcutComponent" />
      <ComponentRef Id="DesktopShortcutComponent" />
    </Feature>

    <!-- Default install location: C:\AMX1\ — user can change this in the installer UI -->
    <DirectoryRef Id="TARGETDIR">
      <Directory Id="INSTALLFOLDER" Name="AMX1" />
    </DirectoryRef>

    <!-- Start Menu folder: Drax -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="DraxStartMenu" Name="Drax" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <!-- Main client EXE component -->
    <ComponentGroup Id="ClientComponents" Directory="INSTALLFOLDER">
      <Component Id="DraxClientExe" Guid="C9D4E5F6-A7B8-9C0D-1E2F-3A4B5C6D7E8F">
        <File Id="DraxClient.exe"
              Source="$(var.DraxClient.TargetDir)DraxClient.exe"
              KeyPath="yes" />
      </Component>
      <!-- DT-small.ico is embedded in the EXE and registered in the MSI's
           internal Icon table (line 19) for ARPPRODUCTICON + the Start
           Menu / Desktop shortcuts. No separate deployed copy is needed
           in the install folder. -->
    </ComponentGroup>

    <!-- Start Menu shortcut (own component for clean uninstall of the folder) -->
    <Component Id="StartMenuShortcutComponent"
               Directory="DraxStartMenu"
               Guid="E1F2A3B4-C5D6-E7F8-A9B0-C1D2E3F4A5B6">
      <Shortcut Id="StartMenuShortcut"
                Name="Drax Technology Client"
                Description="Drax Technology Client"
                Target="[INSTALLFOLDER]DraxClient.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="DraxClient.ico" />
      <RemoveFolder Id="RemoveDraxStartMenu" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\Drax\DraxClient"
                     Name="StartMenuShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <!-- Desktop shortcut -->
    <Component Id="DesktopShortcutComponent"
               Directory="DesktopFolder"
               Guid="F2A3B4C5-D6E7-F8A9-B0C1-D2E3F4A5B6C7">
      <Shortcut Id="DesktopShortcut"
                Name="Drax Technology Client"
                Description="Drax Technology Client"
                Target="[INSTALLFOLDER]DraxClient.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="DraxClient.ico" />
      <RegistryValue Root="HKCU"
                     Key="Software\Drax\DraxClient"
                     Name="DesktopShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <!-- Install-folder confirmation dialog: Welcome → Choose folder → Ready → Progress → Finish -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <WixVariable Id="WixUIBannerBmp" Value="..\Drax360Client\DT-small.ico" />

  </Package>

</Wix>
